<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SMD_Project">
        <activity
            android:name=".SharedActivities.ForgotPasswordOTPActivity"
            android:exported="false" />

        <activity
            android:name=".SharedActivities.ChatActivity"
            android:exported="false" />
        <activity
            android:name=".SharedActivities.OTPActivity"
            android:exported="false" />
        <activity
            android:name=".customer.CustomerActivity"
            android:exported="false" />
        <activity
            android:name=".vendor.activities.VendorActivity"
            android:exported="false" />
        <activity
            android:name=".SharedActivities.SignUp"
            android:exported="false" />
        <activity
            android:name=".SharedActivities.MainActivity"
            android:exported="false" />
        <activity
            android:name=".SharedActivities.Login"
            android:exported="false" />
        <activity
            android:name=".SharedActivities.SplashScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>